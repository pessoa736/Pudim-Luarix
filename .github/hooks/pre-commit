#!/usr/bin/env bash
#
# Git pre-commit hook: Validates ASCII filenames, doc locations, and code patterns
# Install with: cp .github/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
#

set -e

RED='\033[0;31m'
YELLOW='\033[0;33m'
GREEN='\033[0;32m'
NC='\033[0m'  # No Color

ERRORS=0
WARNINGS=0

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only)

##############################################################################
# 1. CHECK ASCII-ONLY FILENAMES
##############################################################################
echo -e "${YELLOW}[1/4] Validating ASCII-only filenames...${NC}"

for file in $STAGED_FILES; do
    # Skip deleted files
    if ! git ls-files --error-unmatch "$file" >/dev/null 2>&1; then
        continue
    fi
    
    # Allow: a-zA-Z, 0-9, dots, hyphens, underscores, slashes
    # Reject: non-ASCII (Unicode, Cyrillic, CJK, etc.)
    if ! echo "$file" | grep -qE '^[a-zA-Z0-9._\/-]+$'; then
        echo -e "${RED}✗ Non-ASCII filename: $file${NC}"
        echo "  Filenames must contain only: a-zA-Z0-9._-/"
        ERRORS=$((ERRORS + 1))
    fi
done

if [ $ERRORS -eq 0 ]; then
    echo -e "${GREEN}✓ All filenames are ASCII-only${NC}"
fi

##############################################################################
# 2. CHECK DOCUMENTATION FILES ARE IN docs/ OR .github/
##############################################################################
echo -e "${YELLOW}[2/4] Validating markdown documentation locations...${NC}"

for file in $STAGED_FILES; do
    # Skip deleted files
    if [ ! -f "$file" ]; then
        continue
    fi
    
    # Check if it's a .md file
    if [[ "$file" == *.md ]]; then
        # Allow .md in docs/ or .github/ or root (README.md, ATTRIBUTIONS.md, lua/README.md)
        if [[ "$file" == docs/* ]] || \
           [[ "$file" == .github/* ]] || \
           [[ "$file" == "README.md" ]] || \
           [[ "$file" == "ATTRIBUTIONS.md" ]] || \
           [[ "$file" == lua/README.md ]]; then
            : # OK
        else
            echo -e "${RED}✗ Markdown file in wrong location: $file${NC}"
            echo "  .md files must be in: docs/, .github/, root (README.md/ATTRIBUTIONS.md), or lua/"
            ERRORS=$((ERRORS + 1))
        fi
    fi
done

if [ $ERRORS -eq 0 ]; then
    echo -e "${GREEN}✓ All documentation is in correct locations${NC}"
fi

##############################################################################
# 3. CHECK C CODE FOR NON-ASCII IDENTIFIERS
##############################################################################
echo -e "${YELLOW}[3/4] Scanning C code for non-ASCII identifiers...${NC}"

for file in $STAGED_FILES; do
    # Skip deleted files or non-C files
    if [ ! -f "$file" ] || ! [[ "$file" == *.{c,h} ]]; then
        continue
    fi
    
    # Look for common non-ASCII patterns (Cyrillic, Greek, CJK)
    # This is a simple heuristic - checks for bytes > 127 in potential identifiers
    if git show ":$file" 2>/dev/null | grep -q '[а-яА-ЯёЁ]'; then
        echo -e "${RED}✗ Cyrillic characters detected in: $file${NC}"
        echo "  Kernel symbols must be ASCII-only [a-zA-Z0-9_]"
        ERRORS=$((ERRORS + 1))
    fi
    
    if git show ":$file" 2>/dev/null | grep -q '[α-ωΑ-Ω]'; then
        echo -e "${RED}✗ Greek characters detected in: $file${NC}"
        echo "  Kernel symbols must be ASCII-only [a-zA-Z0-9_]"
        ERRORS=$((ERRORS + 1))
    fi
    
    if git show ":$file" 2>/dev/null | grep -q '[一-龥]'; then
        echo -e "${RED}✗ CJK (Chinese/Japanese/Korean) characters detected in: $file${NC}"
        echo "  Kernel symbols must be ASCII-only [a-zA-Z0-9_]"
        ERRORS=$((ERRORS + 1))
    fi
done

if [ $ERRORS -eq 0 ]; then
    echo -e "${GREEN}✓ No non-ASCII characters found in C code${NC}"
fi

##############################################################################
# 4. WARN: BUFFER/OVERFLOW CHANGES IN include/
##############################################################################
echo -e "${YELLOW}[4/4] Checking memory safety in include/ changes...${NC}"

UNSAFE_FUNCS=0
for file in $STAGED_FILES; do
    if [[ "$file" != include/* ]] || [ ! -f "$file" ] || ! [[ "$file" == *.{c,h} ]]; then
        continue
    fi
    
    # Check for unsafe C functions
    if git show ":$file" 2>/dev/null | grep -E 'strcpy|sprintf|gets|strcat' >/dev/null; then
        echo -e "${YELLOW}⚠ Unsafe function detected in $file:${NC}"
        git show ":$file" 2>/dev/null | grep -nE 'strcpy|sprintf|gets|strcat' | head -3
        echo "  Consider: luaL_error(), bounds checks, or safe alternatives"
        UNSAFE_FUNCS=$((UNSAFE_FUNCS + 1))
        WARNINGS=$((WARNINGS + 1))
    fi
    
    # Check for missing size limits in Lua bindings
    if echo "$file" | grep -q 'lua\.c$'; then
        if git show ":$file" 2>/dev/null | grep -q 'lua_tostring.*\['; then
            if ! git show ":$file" 2>/dev/null | grep -qE '#define.*MAX'; then
                echo -e "${YELLOW}⚠ Lua binding in $file may need size limit constants${NC}"
                echo "  Add: #define K<MODULE>_MAX_SIZE <limit>"
                WARNINGS=$((WARNINGS + 1))
            fi
        fi
    fi
done

if [ $UNSAFE_FUNCS -eq 0 ]; then
    echo -e "${GREEN}✓ No unsafe functions detected${NC}"
fi

##############################################################################
# SUMMARY
##############################################################################
echo ""
echo "════════════════════════════════════════════════════════════"
if [ $ERRORS -eq 0 ]; then
    echo -e "${GREEN}✓ Pre-commit validation passed!${NC}"
else
    echo -e "${RED}✗ Pre-commit validation FAILED ($ERRORS errors)${NC}"
    echo "  Fix issues above and try 'git commit' again"
    exit 1
fi

if [ $WARNINGS -gt 0 ]; then
    echo -e "${YELLOW}⚠ $WARNINGS warnings - review above${NC}"
fi

echo "════════════════════════════════════════════════════════════"
